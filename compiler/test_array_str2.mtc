// Test array str conversion with various cases
array empty = []
array nums = [1, 2, 3]
array large = [100, 200, 300, 400, 500]

print("Empty array:")
print(str(empty))

print("Number array:")
print(str(nums))

print("Large array:")
print(str(large))

// Test with range
from stdlib.iter use range
array r = range(5)
print("Range(5):")
print(str(r))

print("Done!")