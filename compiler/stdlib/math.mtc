int add(a, b) {
    return a + b
}

int sub(a, b) {
    return a - b
}

int mul(a, b) {
    return a * b
}

int square(n) {
    return n * n
}
int max(arr){
    if (arr.length() == 0){
        return 1
    }
    int lowest = arr[0]
    for (item in arr){
        if (item < lowest){
            set lowest = item
        }
    }
}