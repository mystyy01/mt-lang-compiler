from stdlib.iter use range

class User{
    arg string username = "Guest"
    arg string password = "password123"
    int account_age_seconds = 0

    void speak(){
        print("Hello!")
    }
    void age(){
        set this.account_age_seconds = this.account_age_seconds + 1
    }
}


string divider = "======================================"
string user_name = read("What is your name? ")
User user = new User(user_name, "supersecretpassword")

print(divider)
print("Logged in as:")
print(user.username)
print(divider)
while (user.account_age_seconds < 500){
    user.age()
}
print("User: " + user.username + " is " + str(user.account_age_seconds) + " seconds old.")