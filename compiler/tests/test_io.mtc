from stdlib.io use file_exists
from stdlib.io use File

// Test file_exists function
print("=== Testing file_exists ===")

if (file_exists("test.txt")){
    print("test.txt exists!")
    File f = new File("test.txt", "r")
    array contents = f.readlines()
    print(str(contents))
    for (line in contents){
        print(line)
    }
} else {
    print("test.txt does not exist")
}

if (file_exists("nonexistent_file.xyz")){
    print("nonexistent_file.xyz exists")
} else {
    print("nonexistent_file.xyz does not exist (expected)")
}

print("=== Done ===")
