// Test string.split() method

// Test 1: Split with comma delimiter
string text = "a,b,c"
array parts = text.split(",")
print("Test 1 - Split by comma:")
print(parts[0])
print(parts[1])
print(parts[2])

// Test 2: Split with newline delimiter
string multiline = "hello\nworld\ntest"
array lines = multiline.split("\n")
print("Test 2 - Split by newline:")
print(lines[0])
print(lines[1])
print(lines[2])

// Test 3: String literal split
print("Test 3 - Literal split:")
array words = "one two three".split(" ")
print(words[0])
print(words[1])
print(words[2])
