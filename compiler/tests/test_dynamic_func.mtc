// Test file for func keyword with dynamically typed returns
// This demonstrates static parameter types with dynamic return types

func round(float num) {
    if (num >= 0.5) {
        return 1
    } else {
        return 0.0
    }
}

func divide(int a, int b) {
    if (b == 0) {
        return "Error: Division by zero"
    } else {
        return a / b
    }
}

func test_types(int x) {
    if (x > 0) {
        return 42
    } else if (x < 0) {
        return -3.14
    } else {
        return true
    }
}

// Test calling the functions
int main() {
    print(round(0.7))    // Should print 1 (int)
    print(round(0.3))    // Should print 0.0 (float)
    print(divide(10, 2)) // Should print 5 (int)
    print(divide(10, 0)) // Should print error message
    print(test_types(1))  // Should print 42 (int)
    print(test_types(-1)) // Should print -3.14 (float)
    print(test_types(0))  // Should print true (bool)
    return 0
}