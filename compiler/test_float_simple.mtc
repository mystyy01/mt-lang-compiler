float myfloat = 5.2
int integer = 5
float result1 = integer + myfloat
float result2 = integer / 2.0
float result3 = myfloat * 3.14
float scientific = 1.5e-3
float negative = -3.14
print(myfloat)
print(result1) 
print(result2)
print(result3)
print(scientific)
print(negative)
bool comparison = integer < myfloat
print(comparison)
bool float_comparison = 3.14 < 2.71
print(float_comparison)