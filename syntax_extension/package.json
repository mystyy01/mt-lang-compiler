{
  "name": "mtc-language",
  "displayName": "MTC Language",
  "description": "Syntax highlighting for the MTC programming language",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mtc",
        "aliases": [
          "MTC",
          "mtc"
        ],
        "extensions": [
          ".mtc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mtc",
        "scopeName": "source.mtc",
        "path": "./syntaxes/mtc.tmLanguage.json"
      }
    ]
  }
}
