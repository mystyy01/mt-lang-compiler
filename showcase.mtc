from stdlib.iter use range

int sum_int(num1, num2){
    // int type functions have to return an int, otherwise compiler will shout at you
    if (typeof(num1) == int && typeof(num2) == int){
        return num1 + num2
    }
}

array test_array = ["hello", "goodbye", "good morning", "good afternoon"]
for (item in test_array){
    print(item)
}

for (i12 in range(20)){
    print(i12)
}

print(sum_int(2, 5))

